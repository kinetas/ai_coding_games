# 구현 목표: Network Layer & PvP

CLAUDE.md §3(방 시스템), §10.4(통신 이벤트), §10.3(정보 공개 수준) 기준.

## server/index.js — 전체 구현

```js
const express = require('express');
const { createServer } = require('http');
const { Server } = require('socket.io');
const { v4: uuidv4 } = require('uuid');

const app    = express();
const http   = createServer(app);
const io     = new Server(http, { cors: { origin: '*' } });

app.use(express.static('../client'));

const rooms = new Map();  // roomCode → roomState

// 6자리 방 코드 생성 (CLAUDE.md §3)
function genCode() {
  return Math.random().toString(36).slice(2,8).toUpperCase();
}

function buildSyncPayload(playerState) {
  const cards = playerState.cards || [];
  return {
    pop:         cards.filter(c=>['PERSON','WARRIOR','ARCHER'].includes(c.type)).reduce((s,c)=>s+c.count,0),
    hasWall:     cards.some(c=>c.type==='WALL' && c.count>0),
    cities:      cards.filter(c=>c.type==='CITY').reduce((s,c)=>s+c.count,0),
    kingdomScore: calcKingdomScore(cards),
  };
}

function calcKingdomScore(cards) {
  const city = cards.filter(c=>c.type==='CITY').reduce((s,c)=>s+c.count,0);
  const wall = cards.filter(c=>c.type==='WALL').reduce((s,c)=>s+c.count,0);
  const pop  = cards.filter(c=>['PERSON','WARRIOR','ARCHER'].includes(c.type)).reduce((s,c)=>s+c.count,0);
  return city + Math.floor(wall/10) + Math.floor(pop/5);
}

io.on('connection', (socket) => {
  let currentRoom = null;
  let myRole      = null;  // 'p1' | 'p2'

  // ── 방 만들기 ──
  socket.on('CREATE_ROOM', ({ nickname }) => {
    const code = genCode();
    const room = {
      code, status: 'waiting',
      p1: { id: socket.id, nickname, ready: false, cards: [], combineCount: 0 },
      p2: null,
      timer: null,
      syncInterval: null,
    };
    rooms.set(code, room);
    socket.join(code);
    currentRoom = code;
    myRole = 'p1';
    socket.emit('ROOM_CREATED', { code, role: 'p1' });
  });

  // ── 방 참여 ──
  socket.on('JOIN_ROOM', ({ nickname, code }) => {
    const room = rooms.get(code);
    if (!room || room.p2 || room.status !== 'waiting') {
      socket.emit('JOIN_ERROR', { msg: '입장 불가 방입니다' }); return;
    }
    room.p2 = { id: socket.id, nickname, ready: false, cards: [], combineCount: 0 };
    socket.join(code);
    currentRoom = code;
    myRole = 'p2';
    io.to(code).emit('ROOM_JOINED', { p1: room.p1.nickname, p2: nickname });
    socket.emit('ROOM_JOINED', { code, role: 'p2' });
  });

  // ── Ready 토글 ──
  socket.on('SET_READY', ({ ready }) => {
    const room = rooms.get(currentRoom); if (!room) return;
    room[myRole].ready = ready;
    io.to(currentRoom).emit('READY_UPDATE', {
      p1Ready: room.p1?.ready, p2Ready: room.p2?.ready
    });
  });

  // ── 게임 시작 (방장만) ──
  socket.on('START_GAME', () => {
    const room = rooms.get(currentRoom); if (!room) return;
    if (myRole !== 'p1') return;
    if (!room.p1?.ready || !room.p2?.ready) return;
    room.status = 'countdown';
    io.to(currentRoom).emit('GAME_STARTING');
    let n = 3;
    const cd = setInterval(() => {
      n--;
      io.to(currentRoom).emit('COUNTDOWN', { n });
      if (n <= 0) {
        clearInterval(cd);
        room.status = 'playing';
        io.to(currentRoom).emit('GAME_START');
        // 5초마다 상태 동기화 (CLAUDE.md §10.3)
        room.syncInterval = setInterval(() => _syncStatus(room), 5000);
      }
    }, 1000);
  });

  // ── 조합 성공 전송 (CLAUDE.md §10.4 SEND_COMBINATION) ──
  socket.on('SEND_COMBINATION', ({ cards }) => {
    const room = rooms.get(currentRoom); if (!room) return;
    room[myRole].cards = cards;
    room[myRole].combineCount += 1;
    io.to(currentRoom).emit('COMBINE_UPDATE', {
      role: myRole, combineCount: room[myRole].combineCount
    });
    _checkGameOver(room, currentRoom);
  });

  // ── 약탈자/투석기 파견 (CLAUDE.md §10.4 SPAWN_RAIDER) ──
  socket.on('DISPATCH_UNIT', ({ unitType }) => {
    const room = rooms.get(currentRoom); if (!room) return;
    const opponent = myRole === 'p1' ? room.p2 : room.p1;
    io.to(opponent.id).emit('SPAWN_UNIT', { unitType });
  });

  // ── 척후병 정찰 (CLAUDE.md §10.4 SCOUT_REPORT) ──
  socket.on('SCOUT_START', () => {
    const room = rooms.get(currentRoom); if (!room) return;
    const opponent = myRole === 'p1' ? room.p2 : room.p1;
    // 30초 동안 5초마다 상세 정보 전송
    let ticks = 0;
    const scoutInterval = setInterval(() => {
      ticks++;
      socket.emit('SCOUT_REPORT', _buildScoutReport(opponent));
      if (ticks >= 6) clearInterval(scoutInterval);  // 30초 = 6 * 5초
    }, 5000);
  });

  // ── 왕국 건설 클릭 (선착 판정 — 서버 기준, CLAUDE.md §5.5) ──
  socket.on('KINGDOM_BUILD', ({ cards }) => {
    const room = rooms.get(currentRoom);
    if (!room || room.status !== 'playing') return;
    const score = calcKingdomScore(cards);
    if (score < 30) { socket.emit('KINGDOM_REJECTED', { msg: '점수 부족' }); return; }
    room.status = 'ended';
    clearInterval(room.syncInterval);
    io.to(currentRoom).emit('GAME_OVER', {
      winner: myRole,
      scores: { p1: room.p1.combineCount, p2: room.p2.combineCount }
    });
  });

  // ── 연결 해제 ──
  socket.on('disconnect', () => {
    const room = rooms.get(currentRoom); if (!room) return;
    clearInterval(room.syncInterval);
    if (room.status === 'playing') {
      io.to(currentRoom).emit('OPPONENT_LEFT');
    }
    rooms.delete(currentRoom);
  });

  // ── 내부 헬퍼 ──
  function _syncStatus(room) {
    if (room.p1) io.to(room.p2?.id).emit('SYNC_STATUS', buildSyncPayload(room.p1));
    if (room.p2) io.to(room.p1?.id).emit('SYNC_STATUS', buildSyncPayload(room.p2));
  }

  function _buildScoutReport(target) {
    const cards = target.cards || [];
    return {
      walls:        cards.filter(c=>c.type==='WALL').reduce((s,c)=>s+c.count,0),
      warriors:     cards.filter(c=>c.type==='WARRIOR').reduce((s,c)=>s+c.count,0),
      archers:      cards.filter(c=>c.type==='ARCHER').reduce((s,c)=>s+c.count,0),
      persons:      cards.filter(c=>c.type==='PERSON').reduce((s,c)=>s+c.count,0),
      food:         cards.filter(c=>c.type==='FOOD').reduce((s,c)=>s+c.count,0),
      cities:       cards.filter(c=>c.type==='CITY').reduce((s,c)=>s+c.count,0),
      kingdomScore: calcKingdomScore(cards),
    };
  }

  function _checkGameOver(room, code) {
    const loser = ['p1','p2'].find(role => {
      const cards = room[role]?.cards || [];
      const pop = cards.filter(c=>['PERSON','WARRIOR','ARCHER'].includes(c.type)).reduce((s,c)=>s+c.count,0);
      return pop <= 0;
    });
    if (!loser) return;
    room.status = 'ended';
    clearInterval(room.syncInterval);
    const winner = loser === 'p1' ? 'p2' : 'p1';
    io.to(code).emit('GAME_OVER', {
      winner, scores: { p1: room.p1.combineCount, p2: room.p2.combineCount }
    });
  }
});

http.listen(3000, () => console.log('CardForge Server running on :3000'));
```

## SocketClient.js — 클라이언트 소켓 래퍼

```js
import { io } from 'socket.io-client';

export class SocketClient {
  constructor(scene) {
    this._scene  = scene;
    this._socket = io('http://localhost:3000');
    this._bindEvents();
  }

  // ── 송신 메서드 ──
  createRoom(nickname) { this._socket.emit('CREATE_ROOM', { nickname }); }
  joinRoom(nickname, code) { this._socket.emit('JOIN_ROOM', { nickname, code }); }
  setReady(ready) { this._socket.emit('SET_READY', { ready }); }
  startGame()     { this._socket.emit('START_GAME'); }
  sendCombination(cards) { this._socket.emit('SEND_COMBINATION', { cards: cards.map(c=>c.toJSON()) }); }
  dispatchUnit(unitType)  { this._socket.emit('DISPATCH_UNIT', { unitType }); }
  scoutStart()    { this._socket.emit('SCOUT_START'); }
  kingdomBuild(cards) { this._socket.emit('KINGDOM_BUILD', { cards: cards.map(c=>c.toJSON()) }); }

  // ── 수신 이벤트 바인딩 ──
  _bindEvents() {
    const s = this._socket;
    s.on('ROOM_CREATED',   d => this._scene.events.emit('net:roomCreated',   d));
    s.on('ROOM_JOINED',    d => this._scene.events.emit('net:roomJoined',    d));
    s.on('JOIN_ERROR',     d => this._scene.events.emit('net:joinError',     d));
    s.on('READY_UPDATE',   d => this._scene.events.emit('net:readyUpdate',   d));
    s.on('GAME_STARTING',  () => this._scene.events.emit('net:gameStarting'));
    s.on('COUNTDOWN',      d => this._scene.events.emit('net:countdown',     d));
    s.on('GAME_START',     () => this._scene.events.emit('net:gameStart'));
    s.on('SYNC_STATUS',    d => this._scene.events.emit('net:syncStatus',    d));
    s.on('SPAWN_UNIT',     d => this._scene.events.emit('net:spawnUnit',     d));
    s.on('SCOUT_REPORT',   d => this._scene.events.emit('net:scoutReport',   d));
    s.on('GAME_OVER',      d => this._scene.events.emit('net:gameOver',      d));
    s.on('OPPONENT_LEFT',  () => this._scene.events.emit('net:opponentLeft'));
  }

  disconnect() { this._socket.disconnect(); }
}
