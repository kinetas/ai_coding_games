# 구현 목표: Win/Lose Detection & Result Screen

CLAUDE.md §5.5(승패 조건), §9.3(결과 화면), §9.2(왕국 점수) 기준.

## WinLoseChecker.js

```js
export class WinLoseChecker {
  // 솔로: 인구(사람+전사+궁수) = 0 → 패배
  checkSolo(cards) {
    const pop = cards
      .filter(c => ['PERSON','WARRIOR','ARCHER'].includes(c.type))
      .reduce((s, c) => s + c.count, 0);
    return pop <= 0 ? 'DEFEAT' : null;
  }

  // PvP: 인구 0 → 해당 플레이어 패배 (서버 호출용)
  checkPvP(cards) {
    return this.checkSolo(cards);  // 동일 로직
  }

  // 솔로 최고 점수 저장/비교 (CLAUDE.md §9.3)
  saveBestScore(combineCount, survivalTime) {
    const key = 'cardforge_best';
    const prev = JSON.parse(localStorage.getItem(key) || '{"combineCount":0,"survivalTime":0}');
    const isNew = combineCount > prev.combineCount ||
                 (combineCount === prev.combineCount && survivalTime > prev.survivalTime);
    if (isNew) localStorage.setItem(key, JSON.stringify({ combineCount, survivalTime }));
    return { isNew, prev };
  }

  loadBestScore() {
    return JSON.parse(localStorage.getItem('cardforge_best') || '{"combineCount":0,"survivalTime":0}');
  }
}
```

## ResultScene.js (CLAUDE.md §9.3)

```js
export class ResultScene extends Phaser.Scene {
  constructor() { super('ResultScene'); }

  // data: { mode, result, myScore, opScore, survivalTime, isNewRecord, prevBest }
  create(data) {
    const cx = this.scale.width / 2;
    const cy = this.scale.height / 2;

    // 제목
    const isWin  = data.result === 'WIN';
    const title  = data.mode === 'solo'
      ? '게임 종료'
      : (isWin ? '🏆 승리!' : '💀 패배');
    const tColor = isWin ? '#f5c842' : '#ff4444';

    this.add.text(cx, cy - 180, title,
      { fontSize: '52px', color: tColor, fontStyle: 'bold' }).setOrigin(0.5);

    // 솔로 결과 (CLAUDE.md §9.3 솔로 컬럼)
    if (data.mode === 'solo') {
      const t = data.survivalTime;
      const m = Math.floor(t / 60), s = Math.floor(t % 60);
      this.add.text(cx, cy - 80,
        `조합 횟수: ${data.myScore}회\n생존 시간: ${m}분 ${s}초`,
        { fontSize: '24px', color: '#fff', align: 'center', lineSpacing: 12 }).setOrigin(0.5);

      // 신기록 표시
      if (data.isNewRecord) {
        this.add.text(cx, cy,
          '⭐ 신기록!', { fontSize: '28px', color: '#ffe066', fontStyle: 'bold' }).setOrigin(0.5);
      }
      this.add.text(cx, cy + 40,
        `이전 최고: ${data.prevBest.combineCount}회 / ${Math.floor(data.prevBest.survivalTime/60)}분 ${Math.floor(data.prevBest.survivalTime%60)}초`,
        { fontSize: '16px', color: '#aaaaaa' }).setOrigin(0.5);
    }

    // PvP 결과 (CLAUDE.md §9.3 PvP 컬럼)
    if (data.mode === 'pvp') {
      const myCol = isWin ? '#00ff88' : '#ff4444';
      const opCol = isWin ? '#ff4444' : '#00ff88';
      this.add.text(cx - 100, cy - 60,
        `나\n${data.myScore}회`, { fontSize: '28px', color: myCol, align: 'center' }).setOrigin(0.5);
      this.add.text(cx + 100, cy - 60,
        `상대\n${data.opScore}회`, { fontSize: '28px', color: opCol, align: 'center' }).setOrigin(0.5);
    }

    // 버튼
    this._makeBtn(cx - 100, cy + 140, '재시작', 0x3a7d44, () => {
      this.scene.start('GameScene', { mode: data.mode, nickname: data.nickname });
    });
    this._makeBtn(cx + 100, cy + 140, '로비로', 0x2a5cb8, () => {
      this.scene.start('LobbyScene');
    });
  }

  _makeBtn(x, y, label, color, cb) {
    const bg = this.add.rectangle(x, y, 160, 46, color).setInteractive();
    this.add.text(x, y, label, { fontSize: '18px', color: '#fff' }).setOrigin(0.5);
    bg.on('pointerdown', cb);
  }
}
```

## GameScene에서 ResultScene 전환

```js
// 솔로 패배 처리
_onDefeat() {
  const checker = new WinLoseChecker();
  const { isNew, prev } = checker.saveBestScore(
    this.state.combineCount, this.state.survivalTime
  );
  this.scene.start('ResultScene', {
    mode: 'solo',
    result: 'DEFEAT',
    myScore: this.state.combineCount,
    survivalTime: this.state.survivalTime,
    isNewRecord: isNew,
    prevBest: prev,
    nickname: this.state.nickname,
  });
}

// PvP 종료 처리 (GAME_OVER 소켓 수신 시, CLAUDE.md §10.4)
_onGameOver(payload) {
  // payload: { winner, scores: { p1, p2 }, myRole }
  const myScore = payload.scores[payload.myRole];
  const opScore = payload.scores[payload.myRole === 'p1' ? 'p2' : 'p1'];
  this.scene.start('ResultScene', {
    mode: 'pvp',
    result: payload.winner === payload.myRole ? 'WIN' : 'DEFEAT',
    myScore, opScore,
    nickname: this.state.nickname,
  });
}
```
