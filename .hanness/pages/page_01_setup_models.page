### 3. CardStack.js — 스택 데이터 모델
CLAUDE.md §6.4 기준. count는 항상 1 이상.

```js
export class CardStack {
  constructor(type, count = 1, ratioX = 0.5, ratioY = 0.5) {
    this.id = generateUUID();  // 고유 식별자
    this.type = type;
    this.count = count;
    this.ratioX = ratioX;      // 보드 내 비율 위치 (0~1)
    this.ratioY = ratioY;
    // 위협 카드 전용 필드
    this.expiresAt = null;     // Date.now() + ms, 늑대/곰/약탈자용
    this.busy = false;         // 전사가 교전 중인 경우 true
    this.strength = 1;         // 곰은 3으로 설정
    this.scoutExpiresAt = null; // 척후병 유지 시간
  }

  split(n) {
    // n장 분리 → 새 스택 반환, 원본 count 차감
    const actual = Math.min(n, this.count);
    this.count -= actual;
    return new CardStack(this.type, actual, this.ratioX + 0.05, this.ratioY + 0.05);
  }

  toJSON() {
    return { id: this.id, type: this.type, count: this.count,
             ratioX: this.ratioX, ratioY: this.ratioY };
  }
}
```

### 4. GameState.js — 상태 스키마
CLAUDE.md §10.1, §10.2 기준.

**솔로 상태:**
```js
export function createSoloState(nickname) {
  return {
    mode: 'solo',
    nickname,
    survivalTime: 0,       // 초 단위
    combineCount: 0,
    cards: [],             // CardStack[]
    raidInterval: 60000,   // 다음 약탈자 스폰 간격(ms)
    lastRaidAt: null,
    bestScore: loadBestScore(),  // localStorage
  };
}
```

**PvP 상태 (서버):**
```js
export function createPvPRoomState(roomId) {
  return {
    roomId,
    players: { p1: null, p2: null },
    status: 'waiting',   // 'waiting' | 'countdown' | 'playing' | 'ended'
    timer: 300,          // 5분 제한
    lastSync: Date.now(),
  };
}
```

### 5. server/index.js 뼈대
```js
const express = require('express');
const { createServer } = require('http');
const { Server } = require('socket.io');

const app = express();
const httpServer = createServer(app);
const io = new Server(httpServer, { cors: { origin: '*' } });

app.use(express.static('../client'));

const rooms = new Map();  // roomCode → roomState

io.on('connection', (socket) => {
  console.log('connected:', socket.id);
  // 이벤트 핸들러는 page_08에서 구현
});

httpServer.listen(3000, () => console.log('Server running on port 3000'));
```

