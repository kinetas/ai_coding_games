# 구현 목표: Combat AI & UX Polish

CLAUDE.md §5.7(전투 교환비), §5.8(척후병), §5.6(공격 유닛) 기준.

## CombatResolver.js — 전투 교환비 테이블

```js
// CLAUDE.md §5.7 전투 교환비
const RAIDER_TABLE = [
  // 우선순위 순 (CLAUDE.md §5.7 약탈자 공격 우선순위: 전사→성벽→궁수→사람)
  {
    target: 'WARRIOR',
    ratio: 2,          // 약탈자 1 = 전사 2 제거
    condition: null,
  },
  {
    target: 'WALL',
    ratio: 2,          // 성벽 카드 2장 제거 후 약탈자 소멸
    condition: null,
  },
  {
    target: 'WALL',    // 성벽 + 궁수 동시 존재 시 우선 (1:1)
    ratio: 1,
    condition: (cards) => cards.some(c=>c.type==='ARCHER'&&c.count>0),
    modifiedBy: 'ARCHER',
  },
  {
    target: 'ARCHER',
    ratio: 3,          // 궁수 3명 소모
    condition: null,
  },
  {
    target: 'PERSON',
    ratio: 5,          // 사람 5명 소모
    condition: null,
  },
];

const CATAPULT_TABLE = [
  // CLAUDE.md §5.7 투석기 공격 우선순위: 궁수→성벽→전사→사람
  { target: 'ARCHER',  ratio: 1 },
  { target: 'WALL',    ratio: 3 },
  { target: 'WARRIOR', ratio: 2 },
  { target: 'PERSON',  ratio: 5 },
];

export class CombatResolver {
  // 약탈자 1마리 처리 결과 계산 (CLAUDE.md §5.7)
  resolveRaider(cards) {
    return this._resolve(cards, RAIDER_TABLE, 'RAIDER');
  }

  // 투석기 1기 처리 결과
  resolveCatapult(cards) {
    return this._resolve(cards, CATAPULT_TABLE, 'CATAPULT');
  }

  _resolve(cards, table, unitType) {
    const removals = [];  // { type, count }
    let remaining = 1;    // 처리해야 할 적 수

    // 성벽+궁수 동시 존재 여부 확인 (§5.7 특수 케이스)
    const wallCount   = this._count(cards, 'WALL');
    const archerCount = this._count(cards, 'ARCHER');
    const hasWall     = wallCount > 0;
    const hasArcher   = archerCount > 0;

    // 약탈자 vs 성벽: 궁수 존재 시 1장만 소모
    if (unitType === 'RAIDER' && hasWall) {
      const wallDmg = hasArcher ? 1 : 2;
      removals.push({ type: 'WALL', count: Math.min(wallDmg, wallCount) });
      // 성벽이 흡수했으므로 종료
      return { removals, unitSurvives: false };
    }

    for (const row of table) {
      if (remaining <= 0) break;
      if (row.condition && !row.condition(cards)) continue;
      const avail = this._count(cards, row.target);
      if (avail <= 0) continue;

      const needed  = remaining * row.ratio;
      const actual  = Math.min(needed, avail);
      removals.push({ type: row.target, count: actual });
      remaining -= Math.floor(actual / row.ratio);
    }

    return { removals, unitSurvives: remaining > 0 };
  }

  // 전사 vs 늑대/곰 (CLAUDE.md §7.3 전사 생존 확률)
  resolveWarriorVsWolf(warriorCount, wolfStrength) {
    const warriorRemovals = [];
    if (warriorCount < wolfStrength) {
      // 각 전사: (1 - warriorCount/wolfStrength) 확률로 제거
      const surviveProb = warriorCount / wolfStrength;
      let survived = 0;
      for (let i = 0; i < warriorCount; i++) {
        if (Math.random() < surviveProb) survived++;
      }
      const removed = warriorCount - survived;
      if (removed > 0) warriorRemovals.push({ type: 'WARRIOR', count: removed });
    }
    // warriorCount >= wolfStrength → 전원 생존
    return { warriorRemovals, foodGain: 1 };
  }

  _count(cards, type) {
    return cards.filter(c=>c.type===type).reduce((s,c)=>s+c.count,0);
  }
}
```

## RaiderAI.js — 부유 이동 AI

```js
// 약탈자/투석기 자동 이동 (CLAUDE.md §5.6 "부유 이동")
export class RaiderAI {
  constructor(resolver) {
    this._resolver = resolver;
  }

  // 매 틱 호출. stack: 약탈자 스택, cards: 보드 카드 목록
  tick(stack, cards, dt) {
    if (stack.engagedWith) {
      // 교전 중 — 카운트다운 처리
      stack.combatTimer = (stack.combatTimer || 10000) - dt;
      if (stack.combatTimer <= 0) {
        this._resolveCombat(stack, cards);
      }
      return;
    }

    // 타겟 탐색 (busy 전사 제외, CLAUDE.md §5.7)
    const target = this._findTarget(stack.type, cards);
    if (!target) return;

    // 부유 이동 — 타겟을 향해 서서히 이동
    const dx = target.ratioX - stack.ratioX;
    const dy = target.ratioY - stack.ratioY;
    const dist = Math.sqrt(dx*dx + dy*dy);
    const speed = 0.05 * (dt / 1000);  // 초당 5% 이동

    if (dist < 0.05) {
      // 타겟 도달 → 교전 시작
      stack.engagedWith  = target.id;
      target.busy        = true;  // 전사를 교전 중으로 표시
      stack.combatTimer  = 10000; // 10초
    } else {
      stack.ratioX += (dx / dist) * speed;
      stack.ratioY += (dy / dist) * speed;
    }
  }

  _findTarget(unitType, cards) {
    const priority = unitType === 'RAIDER'
      ? ['WARRIOR', 'WALL', 'ARCHER', 'PERSON']
      : ['ARCHER', 'WALL', 'WARRIOR', 'PERSON'];  // 투석기

    for (const type of priority) {
      const avail = cards.filter(c =>
        c.type === type && c.count > 0 && !c.busy
      );
      if (avail.length > 0) return avail[0];
    }
    return null;
  }

  _resolveCombat(stack, cards) {
    const result = stack.type === 'RAIDER'
      ? this._resolver.resolveRaider(cards)
      : this._resolver.resolveCatapult(cards);

    // 피해 적용
    for (const { type, count } of result.removals) {
      this._deductCards(cards, type, count);
    }

    // 교전 대상 busy 해제
    const engaged = cards.find(c => c.id === stack.engagedWith);
    if (engaged) engaged.busy = false;

    // 약탈자 제거 (항상 소멸)
    stack._toRemove = true;
  }

  _deductCards(cards, type, count) {
    let remaining = count;
    for (const card of cards.filter(c=>c.type===type)) {
      const take = Math.min(card.count, remaining);
      card.count -= take;
      remaining  -= take;
      if (remaining <= 0) break;
    }
    // count 0 스택 제거
    for (let i = cards.length - 1; i >= 0; i--) {
      if (cards[i].count <= 0) cards.splice(i, 1);
    }
  }
}
```

## ArcherDefense.js — 궁수 자동 방어

```js
// 궁수는 적 진입 즉시 자동 반응 (CLAUDE.md §5.7 궁수 방어)
export class ArcherDefense {
  constructor(resolver) {
    this._resolver = resolver;
  }

  // 매 틱 호출. enemies: 보드 위 적 카드 목록
  tick(cards, enemies) {
    const archers = cards.filter(c=>c.type==='ARCHER').reduce((s,c)=>s+c.count,0);
    if (archers <= 0 || enemies.length === 0) return;

    for (const enemy of enemies) {
      if (enemy.busy || enemy.engagedWith) continue;  // 이미 교전 중

      // 궁수 자동 반응
      const result = enemy.type === 'RAIDER'
        ? this._defenseVsRaider(cards, archers)
        : this._defenseVsCatapult(cards, archers);

      for (const { type, count } of result.removals) {
        this._deductCards(cards, type, count);
      }
      if (result.enemyKilled) enemy._toRemove = true;
    }
  }

  _defenseVsRaider(cards, archerCount) {
    // 궁수 3명으로 약탈자 1 제거 (성벽 있으면 궁수 무피해, 성벽만 깎임)
    const hasWall = cards.some(c=>c.type==='WALL'&&c.count>0);
    if (hasWall) {
      return { removals: [{ type: 'WALL', count: 1 }], enemyKilled: true };
    } else {
      const needed = Math.min(3, archerCount);
      return { removals: [{ type: 'ARCHER', count: needed }], enemyKilled: archerCount >= 3 };
    }
  }

  _defenseVsCatapult(cards, archerCount) {
    // 궁수 1:1 투석기 제거
    return { removals: [{ type: 'ARCHER', count: 1 }], enemyKilled: true };
  }

  _deductCards(cards, type, count) { /* RaiderAI._deductCards 와 동일 */ }
}
```

## ScoutManager.js — 척후병 정찰 (CLAUDE.md §5.8)

```js
export class ScoutManager {
  constructor(socket) {
    this._socket = socket;
    this._scoutInfo = null;   // 마지막 수신 정보
    this._active    = false;
  }

  // 척후병 파견 성공 시 호출
  startScouting() {
    this._active = true;
    this._socket.scoutStart();
  }

  // SCOUT_REPORT 수신 시 호출
  onReport(data) {
    this._scoutInfo = data;
  }

  // 정찰 정보 반환 (HUD 갱신용)
  getInfo() {
    return this._active ? this._scoutInfo : null;
  }

  // 척후병 소멸 (30초 후 서버가 중단)
  stopScouting() {
    this._active    = false;
    this._scoutInfo = null;
  }
}
```

## UX 피드백 — 공통 유틸

```js
// GameScene 내 피드백 헬퍼
showCombineResult(success, msg, x, y) {
  const color = success ? '#00cc44' : '#ff2222';
  const icon  = success ? '✓' : '✗';
  const txt = this.add.text(x, y - 50, `${icon} ${msg}`,
    { fontSize: '16px', color, fontStyle: 'bold',
      backgroundColor: '#000000aa', padding: { x:8, y:4 } })
    .setOrigin(0.5).setDepth(100);
  this.tweens.add({
    targets: txt, y: y - 90, alpha: 0,
    duration: 1200, ease: 'Power1',
    onComplete: () => txt.destroy()
  });
}

// 전투 진행 표시 (10초 카운트다운 오버레이)
